# Supabase — copie estes valores do painel: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=https://SEU_PROJETO_ID.supabase.co
VITE_SUPABASE_ANON_KEY=SEU_ANON_PUBLIC_KEY

# Supabase Service Role — MESMO painel (Settings → API), campo "service_role" (secret).
# Usada só no backend (api/telegram-webhook.js) para bypassar RLS via RPC SECURITY DEFINER.
# NUNCA exponha no frontend nem prefixe com VITE_.
SUPABASE_SERVICE_ROLE_KEY=SEU_SERVICE_ROLE_KEY

# Telegram Bot Token — crie o bot com @BotFather no Telegram, comando /newbot.
# O BotFather devolve o token no formato 123456789:ABC-DEF...
TELEGRAM_BOT_TOKEN=SEU_BOT_TOKEN

# Telegram Webhook Secret — gerado por você (ex: `openssl rand -hex 32`), não vem do Telegram.
# Passado como secret_token em setWebhook; o handler rejeita (401) qualquer request
# cujo header X-Telegram-Bot-Api-Secret-Token não bata com este valor.
TELEGRAM_WEBHOOK_SECRET=GERE_UM_SEGREDO_FORTE_ALEATORIO
